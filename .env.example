# Server
PORT=3000

# MPP challenge HMAC key (auto-generated if omitted)
# MPP_SECRET_KEY=your-secret-key-here

# Gateway adapter for production endpoints (sandbox|worldpay|fiserv)
# GATEWAY_ADAPTER=sandbox

# Worldpay configuration (required if GATEWAY_ADAPTER=worldpay)
# WORLDPAY_MERCHANT_CODE=
# WORLDPAY_INSTALLATION_ID=
# WORLDPAY_USERNAME=
# WORLDPAY_PASSWORD=
# WORLDPAY_API_ENDPOINT=https://secure.worldpay.com/jsp/merchant/xml/paymentService.jsp

# Fiserv configuration (required if GATEWAY_ADAPTER=fiserv)
# FISERV_API_KEY=
# FISERV_API_SECRET=
# FISERV_MERCHANT_ID=
# FISERV_API_ENDPOINT=https://cert.api.fiservapps.com/ch/payments/v1/charges
