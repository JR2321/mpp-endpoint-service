# Server
PORT=3000

# MPP secret key for challenge HMAC signing (auto-generated if not set)
MPP_SECRET_KEY=

# Gateway adapter for production mode (default: sandbox)
# Options: sandbox, worldpay, fiserv, custom
GATEWAY_ADAPTER=sandbox

# Worldpay (if GATEWAY_ADAPTER=worldpay)
WORLDPAY_API_KEY=

# Fiserv (if GATEWAY_ADAPTER=fiserv)
FISERV_API_KEY=
