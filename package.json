  "type": "module",
  "dependencies": {
    "@hono/node-server": "^1.19.11",
    "hono": "^4.12.8"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
